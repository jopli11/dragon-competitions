rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin Users Collection
    // Users can only read their own admin status
    match /admin_users/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false; // Admin status can only be changed via Firebase Console or Admin SDK
    }

    // Raffles Collection
    // Publicly readable so users can see competition details and stats
    match /raffles/{raffleId} {
      allow read: if true;
      allow write: if false; // Writes only allowed via Admin SDK (DNA webhook / Cloud Functions)
      
      // Tickets Subcollection
      // Restrict to owner email to prevent PII leakage
      match /tickets/{ticketId} {
        allow read: if request.auth != null && request.auth.token.email == resource.data.email;
        allow write: if false;
      }
    }

    // Orders Collection
    // Users can only read their own orders based on their authenticated email
    match /orders/{orderId} {
      allow read: if request.auth != null && request.auth.token.email == resource.data.email;
      allow write: if false; // Writes only allowed via Admin SDK (DNA webhook)
    }

    // Quiz Passes Collection
    // Private collection used for checkout validation
    match /quizPasses/{passId} {
      allow read: if false; // Only accessible via Admin SDK
      allow write: if false;
    }

    // Webhook Idempotency & Audit Logs
    // Admin SDK Only
    match /processed_events/{eventId} {
      allow read, write: if false;
    }
    match /webhook_events/{eventId} {
      allow read, write: if false;
    }

    // Rate Limiting
    // Admin SDK Only
    match /rateLimits/{limitId} {
      allow read, write: if false;
    }
  }
}
